{
  "name": "api",
  "version": "1.0.0",
  "type": "module",
  "main": "index.js",
  "scripts": {
    "dev": "tsx watch --env-file=../.env src/index.ts",
    "build": "prisma generate && tsc -p tsconfig.json && node -e \"const fs=require('fs');function cp(src,dest){fs.cpSync(src,dest,{recursive:true,force:true})}cp('dist/types','types');cp('dist/lib','lib');fs.copyFileSync('dist/index.js','index.js');fs.rmSync('dist',{recursive:true,force:true});\"",
    "start": "node --env-file=../.env index.js",
    "typecheck": "tsc --noEmit",
    "prisma:generate": "prisma generate"
  },
  "prisma": {
    "generate": "prisma generate"
  },
  "dependencies": {
    "@prisma/adapter-pg": "^7.7.0",
    "@prisma/client": "^7.7.0",
    "@vercel/node": "^3.2.7",
    "@vercel/postgres": "^0.10.0",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.18.2",
    "jsonwebtoken": "^9.0.2",
    "nodemailer": "^8.0.5",
    "pg": "^8.20.0",
    "postgres": "^3.4.4",
    "uuid": "^9.0.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^25.6.0",
    "@types/pg": "^8.20.0",
    "prisma": "^7.7.0",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2"
  }
}
